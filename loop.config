PROJECT_NAME="etsy-dashboard"
MAX_ITERATIONS=20

TEST_CMD='cd /workspace && for f in src/app.js src/routes/index.js src/routes/auth.js src/routes/api.js src/routes/settings.js; do node --check "$f" || exit 1; done; fuser -k 19999/tcp 2>/dev/null; sleep 1; PORT=19999 node src/app.js > /tmp/server.log 2>&1 & SERVER_PID=$!; sleep 5; node scripts/seed.js; rm -f /tmp/cookies.txt; curl -s -c /tmp/cookies.txt -X POST -d "email=demo@example.com&password=password123" http://localhost:19999/login > /dev/null; sleep 1; FAIL=0; check() { CODE=$(curl -s -b /tmp/cookies.txt -o /tmp/resp.html -w "%{http_code}" "http://localhost:19999$1"); if [ "$CODE" != "$2" ]; then echo "FAIL $1 expected $2 got $CODE"; FAIL=1; fi; }; check / 200; check /settings 200; check /api/status 200; node scripts/smoke-test.js || FAIL=1; kill $SERVER_PID 2>/dev/null; wait $SERVER_PID 2>/dev/null; [ $FAIL -eq 0 ] && echo ok || exit 1'

BUILD_CMD=""

LINT_CMD=""

OLLAMA_BASE_URL="http://host.docker.internal:8888"
OLLAMA_MODEL="devstral:24b"
CLOUD_MODEL="claude-sonnet-4-6"
ARCHITECT_DEFAULT_PROVIDER="cloud"
CODER_DEFAULT_PROVIDER="cloud"
REVIEWER_DEFAULT_PROVIDER="cloud"
FAIL_ESCALATE_THRESHOLD=2
MAX_CONSECUTIVE_INFRA_ERRORS=3
ARCHITECT_TIMEOUT=600
CODER_TIMEOUT=2700
REVIEWER_TIMEOUT=300
PORT_RANGE_START=4000
PORT_RANGE_END=4999
CONTAINER_INTERNAL_PORT=3000
PERMISSION_MODE="bypassPermissions"
ALLOWED_TOOLS="Read,Write,Edit,Bash,Glob,Grep"
MAX_TURNS=30
AUTO_COMMIT=true
