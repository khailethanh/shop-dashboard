PROJECT_NAME="etsy-dashboard"
MAX_ITERATIONS=20

TEST_CMD='cd /workspace && for f in src/app.js src/routes/index.js src/routes/auth.js src/routes/api.js src/routes/settings.js; do node --check "$f" || exit 1; done; rm -f /tmp/cookie.txt; TEST_PORT=$((20000 + RANDOM % 10000)); node scripts/seed.js || exit 1; PORT=$TEST_PORT node src/app.js > /tmp/server.log 2>&1 & SERVER_PID=$!; trap "kill -9 $SERVER_PID 2>/dev/null" EXIT; READY=0; for i in $(seq 1 30); do CODE=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$TEST_PORT/api/status" 2>/dev/null); if [ "$CODE" = "200" ]; then READY=1; break; fi; sleep 0.3; done; if [ "$READY" != "1" ]; then echo "FAIL server did not become ready"; cat /tmp/server.log; exit 1; fi; FAIL=0; check() { CODE=$(curl -s -o /tmp/resp.html -w "%{http_code}" $4 "http://localhost:$TEST_PORT$1"); if [ "$CODE" != "$2" ]; then echo "FAIL $1 expected $2 got $CODE"; FAIL=1; fi; if [ -n "$3" ] && grep -q "$3" /tmp/resp.html; then echo "FAIL $1 still contains $3"; FAIL=1; fi; }; check /api/status 200 ""; check / 302 ""; check /settings 302 ""; LOGIN_CODE=$(curl -s -c /tmp/cookie.txt -o /tmp/login_resp.html -w "%{http_code}" -X POST "http://localhost:$TEST_PORT/login" -d "email=demo@example.com&password=password123"); if [ "$LOGIN_CODE" != "302" ]; then echo "FAIL login expected 302 got $LOGIN_CODE"; FAIL=1; fi; if ! grep -q "connect.sid" /tmp/cookie.txt 2>/dev/null; then echo "FAIL login did not set a session cookie"; FAIL=1; fi; check / 200 "" "-b /tmp/cookie.txt"; check /settings 200 "" "-b /tmp/cookie.txt"; check /about 200 ""; node scripts/smoke-test.js "http://localhost:$TEST_PORT" || FAIL=1; [ $FAIL -eq 0 ] && echo ok || exit 1'

BUILD_CMD=""

LINT_CMD=""

OLLAMA_BASE_URL="http://host.docker.internal:8888"
OLLAMA_MODEL="devstral:24b"
CLOUD_MODEL="claude-sonnet-4-6"
ARCHITECT_DEFAULT_PROVIDER="cloud"
CODER_DEFAULT_PROVIDER="cloud"
REVIEWER_DEFAULT_PROVIDER="cloud"
FAIL_ESCALATE_THRESHOLD=2
MAX_CONSECUTIVE_INFRA_ERRORS=3
ARCHITECT_TIMEOUT=600
CODER_TIMEOUT=2700
REVIEWER_TIMEOUT=300
PORT_RANGE_START=4000
PORT_RANGE_END=4999
CONTAINER_INTERNAL_PORT=3000
PERMISSION_MODE="bypassPermissions"
ALLOWED_TOOLS="Read,Write,Edit,Bash,Glob,Grep"
MAX_TURNS=30
AUTO_COMMIT=true
