PROJECT_NAME="etsy-dashboard"
MAX_ITERATIONS=20
TEST_CMD="node --check src/app.js src/routes/index.js src/routes/auth.js src/routes/api.js src/routes/settings.js && echo ok"
BUILD_CMD="cd /workspace && node -e \"
  process.env.PORT=19999;
  const app = require('./src/app.js');
  setTimeout(() => process.exit(0), 1000);
\" 2>&1"
LINT_CMD=""
OLLAMA_BASE_URL="http://host.docker.internal:8888"
OLLAMA_MODEL="devstral:24b"
CLOUD_MODEL="claude-sonnet-4-6"
ARCHITECT_DEFAULT_PROVIDER="cloud"
CODER_DEFAULT_PROVIDER="cloud"
REVIEWER_DEFAULT_PROVIDER="cloud"
FAIL_ESCALATE_THRESHOLD=2
MAX_CONSECUTIVE_INFRA_ERRORS=3
ARCHITECT_TIMEOUT=600
CODER_TIMEOUT=2700
REVIEWER_TIMEOUT=300
PORT_RANGE_START=4000
PORT_RANGE_END=4999
CONTAINER_INTERNAL_PORT=3000
PERMISSION_MODE="bypassPermissions"
ALLOWED_TOOLS="Read,Write,Edit,Bash,Glob,Grep"
MAX_TURNS=30
AUTO_COMMIT=true
