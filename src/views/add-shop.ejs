<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Shop — MyShop Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card">
      <h1 class="auth-title">MyShop Dashboard</h1>
      <h2 class="auth-subtitle">Add your first shop</h2>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form class="auth-form" action="/shops/add" method="POST">
        <div class="form-group">
          <label for="shopName">Shop Name <span class="required">*</span></label>
          <input type="text" id="shopName" name="shopName" class="input" required autofocus
            placeholder="e.g. Artisan Collective"
            value="<%= typeof shopName !== 'undefined' ? shopName : '' %>">
        </div>

        <div class="form-group">
          <label>Currency</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="currency" value="USD" checked> USD
            </label>
            <label class="radio-label">
              <input type="radio" name="currency" value="VND"> VND
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="etsyShopId">Etsy Shop ID <span class="optional">(optional)</span></label>
          <input type="text" id="etsyShopId" name="etsyShopId" class="input"
            placeholder="e.g. 12345678"
            value="<%= typeof etsyShopId !== 'undefined' ? etsyShopId : '' %>">
        </div>

        <button type="submit" class="btn btn-primary btn-full">Add Shop</button>
      </form>

      <p class="auth-switch"><a href="/logout">Sign out</a></p>
    </div>
  </div>
</body>
</html>
