<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — MyShop Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">MyShop Dashboard</a>
      <ul class="nav-links">
        <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Dashboard</a></li>
        <li><a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a></li>
        <li><a href="/settings" class="nav-settings <%= currentPath === '/settings' ? 'active' : '' %>" aria-label="Settings"><i data-lucide="settings"></i></a></li>
      </ul>
    </div>
  </nav>

  <div class="status-bar">
    <span class="status-shop-name"><%= shop.name %></span>
    <% if (shop.isStarSeller) { %>
      <span class="badge badge-star">⭐ Star Seller</span>
    <% } %>
    <span class="status-sales"><%= shop.totalSales %> sales</span>
    <label class="status-vacation">
      <input type="checkbox" id="vacationToggle"> On Vacation
    </label>
    <span class="status-synced">Last synced: <%= new Date(shop.lastSynced).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
  </div>

  <main class="content">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span>© 2026 MyShop Dashboard — Personal Etsy shop tool</span>
      <% if (currentPath === '/') { %>
        <span class="shortcut-hint">Shortcuts: 1-4 switch tabs · R refresh · S settings</span>
      <% } %>
    </div>
  </footer>

  <% if (currentPath === '/') { %>
    <script src="/js/charts.js"></script>
    <script src="/js/app.js"></script>
  <% } %>
  <% if (currentPath === '/settings') { %>
    <script src="/js/settings.js"></script>
  <% } %>
  <script>lucide.createIcons();</script>
</body>
</html>
