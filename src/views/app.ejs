<script>
  window.__REVENUE_DATA__ = <%- JSON.stringify(revenueByDay) %>;
  window.__ANALYTICS__ = <%- JSON.stringify(analyticsData) %>;
  window.__ORDERS_DATA__ = <%- JSON.stringify(orders) %>;
  window.__REVIEWS__ = <%- JSON.stringify(reviews || []) %>;
  window.__SHOPS__ = <%- JSON.stringify(shops || []) %>;
</script>

<div class="tabs-container">
  <div class="tab-buttons" role="tablist">
    <button class="tab-btn active" role="tab" aria-selected="true" data-tab="dashboard">Dashboard</button>
    <button class="tab-btn" role="tab" aria-selected="false" data-tab="listings">Listings</button>
    <button class="tab-btn" role="tab" aria-selected="false" data-tab="orders" id="orders-tab-btn">
      Orders
      <span class="tab-badge" id="overdue-badge" style="display:none">0</span>
    </button>
    <button class="tab-btn" role="tab" aria-selected="false" data-tab="analytics">Analytics</button>
    <button class="tab-btn" role="tab" aria-selected="false" data-tab="reviews">Reviews</button>
  </div>

  <!-- Dashboard Tab -->
  <div id="tab-dashboard" class="tab-panel active">
    <div class="stat-cards">
      <div class="stat-card">
        <span class="stat-label">Total Orders</span>
        <span class="stat-value"><%= stats.totalOrders.value %></span>
        <span class="stat-trend"><%= stats.totalOrders.trend %></span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Revenue</span>
        <span class="stat-value">$<%= stats.revenue.value.toFixed(2) %></span>
        <span class="stat-trend"><%= stats.revenue.trend %></span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Avg Order Value</span>
        <span class="stat-value">$<%= stats.avgOrderValue.value.toFixed(2) %></span>
        <span class="stat-trend"><%= stats.avgOrderValue.trend %></span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Active Listings</span>
        <span class="stat-value"><%= stats.activeListings.value %></span>
        <span class="stat-trend"><%= stats.activeListings.trend %></span>
      </div>
      <div class="stat-card stat-card--clickable" id="pending-fulfillment-card" style="cursor:pointer" title="Click to view pending orders">
        <span class="stat-label">Needs Fulfillment</span>
        <span class="stat-value" id="pending-fulfillment-count">—</span>
        <span class="stat-trend">pending orders</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Avg Rating</span>
        <span class="stat-value" id="avg-rating-value">—</span>
        <span class="stat-trend" id="avg-rating-sub">from reviews</span>
      </div>
    </div>

    <div class="chart-section">
      <h2>Revenue — Last 7 Days</h2>
      <canvas id="revenueChart" height="100"></canvas>
    </div>

    <div class="section">
      <h2>Recent Orders</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Buyer</th>
            <th>Date</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% recentOrders.forEach(order => { %>
          <tr>
            <td><%= order.id %></td>
            <td><%= order.buyerName %></td>
            <td><%= order.date %></td>
            <td><%= order.itemCount %></td>
            <td>$<%= order.total.toFixed(2) %></td>
            <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Listings Tab -->
  <div id="tab-listings" class="tab-panel" hidden>
    <div class="table-controls">
      <input type="text" id="listingsSearch" class="input" placeholder="Search listings…" aria-label="Search listings">
      <select id="listingsSort" class="select">
        <option value="title">Sort by Title</option>
        <option value="price">Sort by Price</option>
        <option value="views">Sort by Views</option>
        <option value="quantity">Sort by Quantity</option>
      </select>
    </div>
    <div id="listingsTableWrap">
      <table class="table" id="listingsTable">
        <thead>
          <tr>
            <th>Title</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Views</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="listingsTbody"></tbody>
      </table>
    </div>
    <div class="pagination" id="listingsPagination"></div>
  </div>

  <!-- Orders Tab -->
  <div id="tab-orders" class="tab-panel" hidden>
    <div class="bulk-action-bar" id="bulk-action-bar" style="display:none">
      <span id="bulk-selected-count">0 selected</span>
      <button class="btn btn-primary" id="bulk-process-btn">Mark as Processing</button>
    </div>
    <div class="orders-toolbar">
      <input id="orders-search" type="text" class="input" placeholder="Search buyer or order ID">
      <select id="orders-sort" class="select">
        <option value="date-desc">Date (newest)</option>
        <option value="date-asc">Date (oldest)</option>
        <option value="total-desc">Total (high–low)</option>
        <option value="total-asc">Total (low–high)</option>
      </select>
      <select id="ordersStatusFilter" class="select">
        <option value="">All Statuses</option>
        <option value="pending">Pending</option>
        <option value="processing">Processing</option>
        <option value="shipped">Shipped</option>
        <option value="delivered">Delivered</option>
        <option value="cancelled">Cancelled</option>
      </select>
      <input type="date" id="ordersDateFrom" class="input" aria-label="From date">
      <input type="date" id="ordersDateTo" class="input" aria-label="To date">
    </div>
    <table class="table" id="ordersTable">
      <thead>
        <tr>
          <th class="checkbox-col"><input type="checkbox" id="orders-select-all" aria-label="Select all orders"></th>
          <th>Order</th>
          <th>Buyer</th>
          <th>Date</th>
          <th>Items</th>
          <th>Total</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="ordersTbody"></tbody>
    </table>
    <div class="pagination-controls">
      <button id="orders-prev">Prev</button>
      <span id="orders-page-info">Showing 1–10 of 0</span>
      <button id="orders-next">Next</button>
    </div>
  </div>

  <!-- Analytics Tab -->
  <div id="tab-analytics" class="tab-panel" hidden>
    <div class="analytics-toolbar">
      <button class="export-csv-btn" id="export-csv-btn">Export CSV</button>
    </div>
    <div class="analytics-grid">
      <div class="side-by-side-charts">
        <div class="chart-section">
          <h2>Top Listings by Views</h2>
          <canvas id="topListingsChart" height="120"></canvas>
        </div>
        <div class="chart-section">
          <h2>Top Listings by Revenue</h2>
          <canvas id="topListingsByRevenueChart" height="120"></canvas>
        </div>
      </div>
      <div class="chart-section">
        <h2>Orders by Day of Week</h2>
        <canvas id="dayOfWeekChart" height="120"></canvas>
      </div>
      <div class="chart-section">
        <div class="period-toggle-row">
          <div class="period-toggle">
            <button class="period-btn active" data-period="monthly">Monthly</button>
            <button class="period-btn" data-period="weekly">Weekly</button>
            <button class="period-btn" data-period="daily">Daily</button>
          </div>
        </div>
        <h2>Revenue <span class="pct-change-badge" id="pct-change-badge">+0%</span></h2>
        <canvas id="revenueMonthChart" height="120"></canvas>
      </div>
      <div class="stat-card conversion-card">
        <span class="stat-label">Conversion Rate</span>
        <span class="stat-value"><%= analyticsData.conversionRate %>%</span>
        <span class="stat-trend">visitors → buyers</span>
      </div>
    </div>
  </div>

  <!-- Reviews Tab -->
  <div id="tab-reviews" class="tab-panel" hidden>
    <div class="reviews-toolbar">
      <label for="reviews-filter-rating" class="sr-only">Filter by rating</label>
      <select id="reviews-filter-rating" class="select">
        <option value="">All Ratings</option>
        <option value="5">5 ★</option>
        <option value="4">4 ★</option>
        <option value="3">3 ★</option>
        <option value="2">2 ★</option>
        <option value="1">1 ★</option>
      </select>
      <label for="reviews-filter-responded" class="sr-only">Filter by response status</label>
      <select id="reviews-filter-responded" class="select">
        <option value="">All</option>
        <option value="responded">Responded</option>
        <option value="not_responded">Not Responded</option>
      </select>
      <label for="reviews-filter-flagged" class="sr-only">Filter by flagged</label>
      <select id="reviews-filter-flagged" class="select">
        <option value="">All</option>
        <option value="flagged">Flagged Only</option>
      </select>
    </div>
    <div id="reviews-list">
      <!-- Review cards are rendered by public/js/app.js -->
    </div>
    <div id="reviews-empty" class="empty-state" style="display:none">
      <p>No reviews match your filters.</p>
    </div>
  </div>
</div>

<!-- Order Detail Modal -->
<div id="orderModal" class="modal-overlay" hidden aria-modal="true" role="dialog">
  <div class="modal-box">
    <button class="modal-close" id="modalClose" aria-label="Close">✕</button>
    <h2 id="modalTitle">Order Detail</h2>
    <div id="modalBody"></div>
    <div class="fulfillment-fields" id="fulfillment-fields" style="display:none">
      <h3>Fulfillment</h3>
      <div class="fulfillment-form">
        <div class="form-group">
          <label for="fulfillment-carrier">Carrier</label>
          <input type="text" id="fulfillment-carrier" class="input" placeholder="e.g. USPS, FedEx, UPS">
        </div>
        <div class="form-group">
          <label for="fulfillment-tracking">Tracking Number</label>
          <input type="text" id="fulfillment-tracking" class="input" placeholder="Enter tracking number">
        </div>
        <button class="btn btn-primary" id="mark-shipped-btn">Mark as Shipped</button>
        <span class="fulfillment-msg" id="fulfillment-msg"></span>
      </div>
    </div>
  </div>
</div>
