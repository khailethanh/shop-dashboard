<div class="settings-page">
  <h1>Settings</h1>

  <form id="settingsForm" class="settings-form" action="/settings/save" method="POST">
    <div class="form-group">
      <label for="shopName">Shop Name</label>
      <input type="text" id="shopName" name="shopName" class="input" placeholder="Your shop name">
    </div>

    <div class="form-group">
      <label>Currency</label>
      <div class="radio-group">
        <label><input type="radio" name="currency" value="USD"> USD ($)</label>
        <label><input type="radio" name="currency" value="EUR"> EUR (€)</label>
        <label><input type="radio" name="currency" value="GBP"> GBP (£)</label>
      </div>
    </div>

    <div class="form-group">
      <label>Date Format</label>
      <div class="radio-group">
        <label><input type="radio" name="dateFormat" value="MM/DD/YYYY"> MM/DD/YYYY</label>
        <label><input type="radio" name="dateFormat" value="DD/MM/YYYY"> DD/MM/YYYY</label>
        <label><input type="radio" name="dateFormat" value="YYYY-MM-DD"> YYYY-MM-DD</label>
      </div>
    </div>

    <div class="form-group">
      <label for="etsyApiKey">Etsy API Key</label>
      <input type="password" id="etsyApiKey" name="etsyApiKey" class="input" placeholder="Enter your Etsy API key">
    </div>

    <button type="button" id="saveSettings" class="btn btn-primary">Save Settings</button>
  </form>

  <div class="connection-section">
    <h2>Connection</h2>
    <div class="connection-info">
      <div class="connection-row">
        <span class="connection-label">Status</span>
        <span class="connection-value connection-status-connected">Connected</span>
      </div>
      <div class="connection-row">
        <span class="connection-label">Last synced</span>
        <span class="connection-value">2026-07-06 08:00 UTC</span>
      </div>
      <div class="connection-row">
        <span class="connection-label">Next sync</span>
        <span class="connection-value">Automatic</span>
      </div>
    </div>
  </div>

  <div id="settingsToast" class="toast" hidden>Settings saved ✓</div>
</div>
