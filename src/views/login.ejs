<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Log In — MyShop Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card">
      <h1 class="auth-title">MyShop Dashboard</h1>
      <h2 class="auth-subtitle">Log in to your account</h2>

      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form class="auth-form" action="/login" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" class="input" required autofocus placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" class="input" required placeholder="Your password">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Log In</button>
      </form>

      <p class="auth-switch">Don't have an account? <a href="/signup">Sign up</a></p>
    </div>
  </div>
</body>
</html>
